{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aggregate Spec",
  "type": "object",
  "required": ["name", "fields"],
  "properties": {
    "name": { "type": "string" },
    "fields": {
      "type": "array",
      "items": { "$ref": "#/definitions/field" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "field": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": {
          "anyOf": [
            { "type": "string" },
            { "$ref": "#/definitions/objectType" }
          ]
        },
        "nonNull": { "type": "boolean" },
        "isList": { "type": "boolean" },
        "nonNullItem": { "type": "boolean" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/definitions/field" }
        }
      },
      "additionalProperties": false
    },
    "objectType": {
      "type": "object",
      "required": ["fields"],
      "properties": {
        "fields": { "type": "array", "items": { "$ref": "#/definitions/field" } }
      },
      "additionalProperties": false
    }
  }
}
